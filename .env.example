# Database
DB_PASSWORD=changeme_strong_password

# Azure AD (optional - leave empty for local-auth-only mode)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# SMTP (optional - leave empty to disable emails)
# Leave SMTP_PORT empty so docker-compose.override.yml defaults it to 1025 (MailHog's
# SMTP port). A non-empty value here (e.g. 587) overrides that default and breaks local/CI
# mail delivery to MailHog. Set a real host+port only when wiring a real SMTP server.
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@schulerpark.local

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_minimum_32_bytes

# App
ASPNETCORE_ENVIRONMENT=Development

# --- Production only (used with docker-compose.prod.yml) ---
# Public hostname for the Caddy Let's Encrypt cert. Caddy auto-issues via the
# inbound HTTP-01 / TLS-ALPN-01 challenge (requires IT to open inbound :80/:443).
SITE_DOMAIN=louise.schuler.de
# ACME contact address (Let's Encrypt notices)
ACME_EMAIL=admin@schuler.de
# ACME CA endpoint — staging for first issuance, then flip to production:
#   ACME_CA=https://acme-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
# Corporate proxy for Caddy's outbound ACME traffic (required on the Schuler box;
# leave empty for direct outbound internet).
CADDY_HTTP_PROXY=http://193.28.217.25:3128
CADDY_HTTPS_PROXY=http://193.28.217.25:3128

# DB backup retention in days
BACKUP_RETENTION_DAYS=30
# Optional: encrypt DB dumps at rest (AES-256). Keep a copy of this passphrase
# OFF this box -- an encrypted backup is worthless without it.
BACKUP_PASSPHRASE=

# VAPID keys for Web Push notifications (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@schulerpark.local
