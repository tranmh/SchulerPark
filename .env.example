# Database
DB_PASSWORD=changeme_strong_password

# Azure AD (optional - leave empty for local-auth-only mode)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# SMTP (optional - leave empty to disable emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@schulerpark.local

# JWT
JWT_SECRET=change_this_to_a_random_64_char_string_minimum_32_bytes

# App
ASPNETCORE_ENVIRONMENT=Development

# --- Production only (used with docker-compose.prod.yml) ---
# Public hostname for the Caddy Let's Encrypt certificate (DNS-01 challenge)
SITE_DOMAIN=park.schuler.de
# ACME contact address (Let's Encrypt notices)
ACME_EMAIL=admin@schuler.de
# DNS provider API token for the DNS-01 challenge (default plugin: Cloudflare).
# See docs/plans/phase-15-letsencrypt-dns01.md.
CF_API_TOKEN=
# Optional corporate proxy for Caddy's outbound ACME traffic (leave empty for direct)
CADDY_HTTP_PROXY=
CADDY_HTTPS_PROXY=

# DB backup retention in days
BACKUP_RETENTION_DAYS=30

# VAPID keys for Web Push notifications (optional — generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@schulerpark.local
