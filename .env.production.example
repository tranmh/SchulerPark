# Database (use a strong password!)
DB_PASSWORD=<generate-a-strong-random-password>

# --- TLS / Let's Encrypt (Caddy, HTTP-01 / TLS-ALPN-01 challenge) ---
# Caddy auto-issues + auto-renews a publicly-trusted cert. The ACME challenge is
# INBOUND: Let's Encrypt connects to this box on :80/:443, so Schuler IT must open
# an inbound firewall/NAT rule for those ports. (DNS-01 is NOT used — the schuler.de
# zone is on Cloudflare *secondary* / master ns1.schuler-isp.net, which we can't
# write challenge records to. No CF_API_TOKEN / DNS plugin is involved.)
#
# Public hostname the cert is issued for. Must be a real, publicly-resolvable
# domain (LE cannot issue for a bare IP). louise.schuler.de already resolves to the
# box's public IP.
SITE_DOMAIN=louise.schuler.de
# ACME contact address (Let's Encrypt expiry / recovery notices).
ACME_EMAIL=admin@schuler.de
# ACME CA endpoint. Leave as staging for the FIRST issuance (staging has generous
# rate limits and its cert is untrusted-but-harmless); once the staging cert is
# obtained, switch to production and force-recreate caddy to get a trusted cert:
#   ACME_CA=https://acme-v02.api.letsencrypt.org/directory
ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
# Corporate proxy for Caddy's OUTBOUND ACME traffic (reaching LE's ACME API).
# REQUIRED on this box — direct egress is refused; the proxy tunnels to acme-v02.
# Internal hops (app, db, *.schuler.de, the box IP) are already excluded via NO_PROXY.
CADDY_HTTP_PROXY=http://193.28.217.25:3128
CADDY_HTTPS_PROXY=http://193.28.217.25:3128

# Azure AD SSO (OPTIONAL — leave empty for local-auth-only mode).
# When empty, the "Sign in with Microsoft" button is hidden and the app uses
# local username/password auth only.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# SMTP (production mail server)
SMTP_HOST=smtp.your-server.com
SMTP_PORT=587
SMTP_USERNAME=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM_ADDRESS=noreply@schulerpark.de

# JWT (use a strong random secret, minimum 64 chars)
JWT_SECRET=<generate-a-strong-random-secret>

# Web Push (VAPID) keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@schulerpark.de

# Backup retention in days
BACKUP_RETENTION_DAYS=30
# Optional: encrypt DB dumps at rest (AES-256, see scripts/db-backup.sh).
# Keep a copy of this passphrase OFF this box.
BACKUP_PASSPHRASE=
