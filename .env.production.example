# Database (use a strong password!)
DB_PASSWORD=<generate-a-strong-random-password>

# --- TLS / Let's Encrypt (Caddy, DNS-01 challenge) ---
# Public hostname the cert is issued for. Must be a real domain (LE cannot issue
# for a bare IP). DNS-01 keeps the box intranet-only — no inbound :80/:443 needed.
SITE_DOMAIN=park.schuler.de
# ACME contact address (Let's Encrypt expiry / recovery notices).
ACME_EMAIL=admin@schuler.de
# DNS provider API token so Caddy can write the _acme-challenge TXT record.
# Default plugin is Cloudflare (caddy-dns/cloudflare) — token needs DNS:Edit on
# the schuler.de zone. For a different provider, change CADDY_DNS_MODULE in
# Dockerfile.caddy and the `dns` directive in the Caddyfile. See
# docs/plans/phase-15-letsencrypt-dns01.md.
CF_API_TOKEN=<dns-provider-api-token>
# Optional: corporate proxy for Caddy's OUTBOUND ACME traffic. Leave empty if the
# box has direct outbound internet. Internal hops are already excluded via NO_PROXY.
CADDY_HTTP_PROXY=
CADDY_HTTPS_PROXY=

# Azure AD SSO (OPTIONAL — leave empty for local-auth-only mode).
# When empty, the "Sign in with Microsoft" button is hidden and the app uses
# local username/password auth only.
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# SMTP (production mail server)
SMTP_HOST=smtp.your-server.com
SMTP_PORT=587
SMTP_USERNAME=<smtp-user>
SMTP_PASSWORD=<smtp-password>
SMTP_FROM_ADDRESS=noreply@schulerpark.de

# JWT (use a strong random secret, minimum 64 chars)
JWT_SECRET=<generate-a-strong-random-secret>

# Web Push (VAPID) keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@schulerpark.de

# Backup retention in days
BACKUP_RETENTION_DAYS=30
