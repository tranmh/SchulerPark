{
	# Requests that arrive without SNI (e.g. direct-IP intranet access) fall back
	# to this site, so they are still served.
	default_sni 193.28.217.49
}

# ── Production site ──
# louise.schuler.de is the canonical hostname (SITE_DOMAIN). park.schuler.de is
# kept as an alias for old bookmarks/links — it is DNS-aliased to louise. Both,
# plus localhost (deploy.sh health probe / SSH-tunnel access) and the direct IP,
# are served the same app over Caddy's internal self-signed CA.
{$SITE_DOMAIN:louise.schuler.de}, park.schuler.de, localhost, 193.28.217.49 {
	# Intranet deployment: use Caddy's built-in self-signed CA instead of Let's Encrypt.
	# Replace with `tls /path/to/cert /path/to/key` once Schuler IT issues an internal-CA cert.
	tls internal

	reverse_proxy app:8080

	header {
		# Security headers
		# HSTS disabled while running on Caddy's internal self-signed CA — once IT
		# issues a real cert, restore: max-age=31536000; includeSubDomains; preload
		Strict-Transport-Security "max-age=0"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Remove server identification
		-Server
	}
}

# Explicit HTTP block prevents Caddy's default HTTP->HTTPS redirect,
# which would cause a redirect loop when Cloudflare SSL is set to Flexible.
http://{$SITE_DOMAIN:louise.schuler.de}, http://park.schuler.de {
	reverse_proxy app:8080
}
