{
	# ACME account contact for the auto-issued Let's Encrypt certs.
	email {$ACME_EMAIL}
	# ACME CA endpoint. Defaults to LE STAGING so the first issuance can't burn the
	# production rate limit while we confirm the inbound challenge works. Flip to
	# https://acme-v02.api.letsencrypt.org/directory (via ACME_CA in .env) once a
	# staging cert has been obtained successfully.
	acme_ca {$ACME_CA:https://acme-staging-v02.api.letsencrypt.org/directory}
	# Requests that arrive without SNI (e.g. direct-IP intranet access) fall back
	# to this site, so they are still served.
	default_sni 193.28.217.49
}

# Shared security headers. HSTS is intentionally NOT here — it belongs only on the
# publicly-trusted (Let's Encrypt) site, never on the internal-CA hosts.
(security_headers) {
	header {
		# 'unsafe-inline' for styles: React style={} attributes need it.
		# login.microsoftonline.com in connect-src: MSAL token exchange (Azure SSO).
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://login.microsoftonline.com; manifest-src 'self'; worker-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Remove server identification
		-Server
	}
}

# ── Public site: publicly-trusted Let's Encrypt cert ──
# louise.schuler.de is canonical (SITE_DOMAIN); park.schuler.de is a DNS alias for
# old bookmarks/links. Caddy auto-issues AND auto-renews the cert via the ACME
# HTTP-01 / TLS-ALPN-01 challenge. Those challenges require inbound :80/:443 to be
# reachable from the public internet (Schuler IT firewall/NAT rule) — until that
# is open, issuance will fail the challenge and Caddy keeps retrying.
{$SITE_DOMAIN:louise.schuler.de}, park.schuler.de {
	reverse_proxy app:8080

	import security_headers
	# HSTS: start conservative now that a trusted cert is live; raise toward
	# max-age=31536000 (+ includeSubDomains; preload) after a burn-in period.
	header Strict-Transport-Security "max-age=86400"
}

# ── Internal access: Caddy's self-signed internal CA ──
# localhost (deploy.sh's `curl -k https://localhost/api/health` probe and the
# SSH-tunnel access path) and the direct IP. Let's Encrypt cannot issue for a bare
# IP or for localhost, and these hosts aren't publicly resolvable, so they stay on
# the internal CA. No HSTS here — the cert is untrusted by design.
localhost, 127.0.0.1, 193.28.217.49 {
	tls internal
	reverse_proxy app:8080

	import security_headers
}

# No plaintext http:// site block: Caddy's default HTTP->HTTPS 308 redirect on
# port 80 must stay active so logins can never travel over cleartext HTTP. Port 80
# also serves the ACME HTTP-01 challenge, so it must remain open to Caddy.
